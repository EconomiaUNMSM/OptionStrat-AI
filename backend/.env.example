# Configuración de Entorno de Inteligencia Artificial
# Seleccionar proveedor ('openai' u 'openrouter')
AI_PROVIDER=openai

# CLAVES API (Reemplaza con tus propias claves)
OPENAI_API_KEY=tu_clave_openai_aqui
OPENROUTER_API_KEY=tu_clave_openrouter_aqui

# MODELOS (Ajusta según las capacidades que necesites y tu proveedor)
OPENAI_DEFAULT_CHAT_MODEL=gpt-4o
DEFAULT_CHAT_MODEL=openrouter/free
